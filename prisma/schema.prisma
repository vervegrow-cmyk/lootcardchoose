generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GalleryCard {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  tags        String[]
  style       String?
  rarity      String?
  category    String?
  character   String?
  color       String?
  price       Decimal
  metadata    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
}

model GallerySearchSession {
  id                    String   @id @default(cuid())
  discordGuildId        String?
  discordUserId         String
  discordChannelId      String
  query                 String
  results               Json
  selectedGalleryCardId String?
  status                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([discordGuildId, discordChannelId, discordUserId, createdAt])
}

model Order {
  id                  String   @id @default(cuid())
  orderNumber         String
  discordUserId       String
  galleryCardId       String
  preferredLanguage   String?
  shopifyProductId    String?
  productCode         String?
  shopifyCheckoutUrl  String?
  shopifyProductUrl   String?
  shopifyShareImageUrl String?
  shopifyProductHandle String?
  amount              Decimal
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  galleryCard          GalleryCard @relation(fields: [galleryCardId], references: [id])
}

model ShopifyWebhookEvent {
  id                  String   @id @default(cuid())
  topic               String
  shopifyWebhookId    String?
  shopifyOrderId      String?
  payload             Json
  resolvedOrderNumber String?
  resolvedMethod      String?
  status              String
  failureReason       String?
  processedAt         DateTime?
  createdAt           DateTime @default(now())
}

model RecommendationAnalyticsDaily {
  id                String   @id @default(cuid())
  dateKey           String
  timezone          String
  sourceFile        String
  sourceWindowStart DateTime?
  sourceWindowEnd   DateTime?
  searchCount       Int
  impressions       Int
  selections        Int
  checkoutCreated   Int
  purchases         Int
  selectionRate     Float
  checkoutRate      Float
  purchaseRate      Float
  reportPayload     Json
  generatedAt       DateTime @default(now())

  @@unique([dateKey, timezone, sourceFile])
}

model RecommendationAnalyticsSnapshot {
  id                String   @id @default(cuid())
  sourceFile        String
  timezone          String
  sourceWindowStart DateTime?
  sourceWindowEnd   DateTime?
  summaryPayload    Json
  generatedAt       DateTime @default(now())
}

model ShopifyShop {
  id          String   @id @default(cuid())
  shop        String   @unique
  accessToken String
  scope       String?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
